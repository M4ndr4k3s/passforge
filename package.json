{
  "name": "passforge",
  "productName": "PassForge",
  "version": "0.1.0",
  "description": "Gerador de senhas e cofre local criptografado — offline-first",
  "author": "Mdk Software",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "node test/crypto-roundtrip.mjs && node test/totp.mjs",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.mdksoftware.passforge",
    "files": ["main.js", "preload.js", "src/**"],
    "win": { "target": ["nsis", "portable"] },
    "mac": { "target": ["dmg", "zip"] },
    "publish": [{ "provider": "github", "owner": "M4ndr4k3s", "repo": "passforge" }]
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
